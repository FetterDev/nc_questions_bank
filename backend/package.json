{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "npm run prisma:generate",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "echo 'backend lint is not configured yet'",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "bootstrap:admin": "node scripts/bootstrap-admin.js",
    "seed:question-bank": "node scripts/seed-question-bank.js",
    "test:seed:question-bank": "node --test test/question-bank.data.test.mjs",
    "test:integration:auth": "npm run build && node --test test/integration/auth.integration.test.mjs",
    "test:integration:companies": "npm run build && node --test test/integration/companies.integration.test.mjs",
    "test:integration:competencies": "npm run build && node --test test/integration/competencies.integration.test.mjs",
    "test:integration:interviews": "npm run build && node --test test/integration/interviews.integration.test.mjs",
    "test:integration:topics": "npm run build && node --test test/integration/topics.integration.test.mjs",
    "test:integration:training": "npm run build && node --test test/integration/training.integration.test.mjs",
    "openapi:generate:dist": "node scripts/generate-openapi.js",
    "openapi:generate": "npm run build && npm run openapi:generate:dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.3",
    "@nestjs/platform-express": "^11.0.3",
    "@nestjs/swagger": "^11.2.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}

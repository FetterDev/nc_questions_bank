        </mxCell>
        <mxCell id="11" parent="1" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#93c5fd;strokeWidth=1;fontColor=#1e3a8a;fontSize=12;align=left;spacing=12;" value="&lt;b&gt;OpenAPI contract&lt;/b&gt;&lt;br/&gt;`openapi.json` генерируется из controller + DTO + validation decorators.&lt;br/&gt;Любой API change должен обновлять контракт в том же change set." vertex="1">
          <mxGeometry height="78" width="290" x="450" y="202" as="geometry" />
        </mxCell>
        <mxCell id="12" parent="1" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#93c5fd;strokeWidth=1;fontColor=#1e3a8a;fontSize=12;align=left;spacing=12;" value="&lt;b&gt;Roles and guards&lt;/b&gt;&lt;br/&gt;Global `RolesGuard` as `APP_GUARD`. `StrictRoles` only for own history/runtime/analytics endpoints; `Roles` everywhere else.&lt;br/&gt;Admin override works only for `Roles`." vertex="1">
          <mxGeometry height="78" width="380" x="780" y="202" as="geometry" />
        </mxCell>
        <mxCell id="13" parent="1" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1;fontColor=#475569;fontSize=12;align=left;spacing=12;" value="&lt;b&gt;Boundary rule&lt;/b&gt;&lt;br/&gt;controller -&amp;gt; service -&amp;gt; repository only.&lt;br/&gt;Repository never calls service. The only direct service -&amp;gt; service dependency is `AuthService -&amp;gt; UsersService`." vertex="1">
          <mxGeometry height="78" width="500" x="1200" y="202" as="geometry" />
        </mxCell>
        <mxCell id="20" parent="1" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#93c5fd;strokeWidth=2;overflow=fill;spacing=0;shadow=0;" value="&lt;table cellpadding=&quot;0&quot; cellspacing=&quot;0&quot; style=&quot;width:100%;height:100%;font-family:Helvetica,Arial,sans-serif;font-size:13px;&quot;&gt;&lt;tr&gt;&lt;td style=&quot;background:#dbeafe;padding:12px 14px;border-bottom:1px solid #93c5fd;font-weight:700;font-size:16px;color:#0f172a;&quot;&gt;Auth / Authz&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:12px 14px;line-height:1.65;color:#0f172a;&quot;&gt;`auth.controller`&lt;br/&gt;`auth.service`&lt;br/&gt;JWT middleware&lt;br/&gt;`RolesGuard`, `Roles`, `StrictRoles`&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" vertex="1">

        <mxCell id="10" parent="1" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;strokeWidth=1;fontColor=#475569;fontSize=12;align=left;spacing=12;" value="&lt;b&gt;Schema + migrations&lt;/b&gt;&lt;br/&gt;`schema.prisma` = PK/FK, enums, nullable, Prisma indexes.&lt;br/&gt;SQL migrations = partial unique, CHECK, pg_trgm, final PostgreSQL DDL." vertex="1">

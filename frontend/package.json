{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:with-sdk": "npm run sdk:generate && npm run build",
    "preview": "vite preview",
    "lint": "echo 'frontend lint is not configured yet'",
    "sdk:generate": "openapi-typescript ../backend/openapi.json -o src/sdk/generated.ts",
    "ui:snap": "node ./scripts/ui-snapshots/capture.mjs",
    "ui:snap:install": "playwright install chromium",
    "ui:smoke:test": "playwright test --config=playwright.smoke.config.ts",
    "ui:snap:test": "playwright test",
    "ui:snap:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@mdi/js": "^7.4.47",
    "codemirror": "^6.0.2",
    "openapi-fetch": "^0.17.0",
    "shiki": "^4.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "openapi-typescript": "^7.13.0",
    "sass": "^1.97.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^2.2.0"
  }
}
